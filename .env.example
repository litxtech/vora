# =============================================================================
# Vora — ortam değişkenleri şablonu
# Kopyala: cp .env.example .env
# Kod eşlemesi: docs/ENVIRONMENT.md
# =============================================================================

# --- Expo / CI (asla commit etmeyin) -----------------------------------------
EXPO_TOKEN=

# --- Geliştirme --------------------------------------------------------------
# Kod: env.dev.isDemoDataEnabled
# EXPO_PUBLIC_ENABLE_DEMO_DATA=true

# --- Supabase (zorunlu) ------------------------------------------------------
# Kod: env.supabase.url / env.supabase.anonKey
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase CLI — db push, link (asla commit etmeyin)
SUPABASE_ACCESS_TOKEN=

# --- Agora — sesli/görüntülü arama -------------------------------------------
# Kod: env.agora.appId
EXPO_PUBLIC_AGORA_APP_ID=
# AGORA_APP_CERTIFICATE → yalnızca Supabase secrets (istemciye konmaz)

# --- Mapbox — Android harita -------------------------------------------------
# Kod: env.mapbox.accessToken
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-public-token

# --- Firebase — Android push -------------------------------------------------
# Kod: env.firebase.*
# google-services.json veya: npm run ensure:google-services
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# --- Stripe — istemci --------------------------------------------------------
# Kod: env.stripe.publishableKey
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# --- Paylaşım linkleri -------------------------------------------------------
# Kod: env.share.baseUrl / env.stores.*
# Varsayılan domain: vora.app (APP_DOMAIN sabiti)
# EXPO_PUBLIC_SHARE_BASE_URL=https://vora.app
# EXPO_PUBLIC_IOS_APP_STORE_URL=https://apps.apple.com/app/vora/idXXXXXXXX
# EXPO_PUBLIC_ANDROID_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.karadeniz.dijitalagi

# --- Yasal belgeler (harici URL; boşsa uygulama içi ekran) -------------------
# Kod: env.legal.*
# EXPO_PUBLIC_TERMS_OF_USE_URL=https://litxtech.com/vora/terms
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://litxtech.com/vora/privacy
# EXPO_PUBLIC_CHILD_PROTECTION_POLICY_URL=https://litxtech.com/vora/child-protection

# =============================================================================
# Aşağıdakiler yalnızca Supabase Edge Function secrets veya CI'da tutulur.
# .env'e yazılabilir (local function test) ama asla commit edilmez.
# =============================================================================

# Mux (video)
# MUX_TOKEN_ID=
# MUX_TOKEN_SECRET=

# Vora AI
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash
# AI_VISION_API_KEY=
# AI_VISION_BASE_URL=https://api.openai.com
# AI_VISION_MODEL=gpt-4o-mini

# Stripe (sunucu)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_MONTHLY=price_...
# STRIPE_PRICE_YEARLY=price_...

# Apple IAP (sunucu)
# APPLE_ISSUER_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# APPLE_BUNDLE_ID=com.karadeniz.dijitalagi

# Google Play Billing (sunucu)
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_PLAY_PACKAGE_NAME=com.karadeniz.dijitalagi

# share-preview — App Links / Universal Links
# ANDROID_SHA256_FINGERPRINT=AA:BB:CC:...
# ANDROID_SHA256_FINGERPRINTS=AA:BB:CC:...,DD:EE:FF:...
# APPLE_TEAM_ID=9W6CR7KXM7
