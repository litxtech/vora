# Expo (EAS CLI / CI — asla commit etmeyin)
EXPO_TOKEN=

# Geliştirme — sahte içerik ve "Yakında" butonları (production'da false veya boş bırakın)
# EXPO_PUBLIC_ENABLE_DEMO_DATA=true

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Supabase CLI / Management API (db push, link — asla commit etmeyin)
SUPABASE_ACCESS_TOKEN=

# Mux (video altyapısı - Edge Function tarafında kullanılır)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Vora AI — DeepSeek (metin) + isteğe bağlı vision sağlayıcı (görsel/video analizi)
# DeepSeek chat API görsel desteklemez; görsel analiz için AI_VISION_* ayrı tanımlanır.
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash
# AI_VISION_API_KEY=
# AI_VISION_BASE_URL=https://api.openai.com
# AI_VISION_MODEL=gpt-4o-mini

# Agora (sesli/görüntülü arama)
EXPO_PUBLIC_AGORA_APP_ID=
# AGORA_APP_CERTIFICATE yalnızca Supabase secrets'ta tutulur (istemciye konmaz)

# Mapbox (Android harita — public token)
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-public-token

# Firebase (Android push — google-services.json veya env ile üretilir)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
# Cloud Messaging → Sender ID (Firebase project settings → General → Project number)
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# Paylaşım linkleri (WhatsApp önizleme + uygulama yönlendirme)
# Varsayılan: https://vora.app — DNS bu domain'i Supabase share-preview edge function'a yönlendirmeli
# (Supabase Dashboard → Project Settings → Custom Domains → vora.app)
# EXPO_PUBLIC_SHARE_BASE_URL=https://vora.app
#
# Android App Links doğrulaması (Supabase secrets — share-preview function):
# Play Console → Kurulum → Uygulama bütünlüğü → Uygulama imzalama anahtarı → SHA-256
# Birden fazla parmak izi (upload + app signing) virgülle ayrılabilir.
# ANDROID_SHA256_FINGERPRINT=AA:BB:CC:...
# ANDROID_SHA256_FINGERPRINTS=AA:BB:CC:...,DD:EE:FF:...
# APPLE_TEAM_ID=9W6CR7KXM7
# EXPO_PUBLIC_IOS_APP_STORE_URL=https://apps.apple.com/app/vora/idXXXXXXXX
# EXPO_PUBLIC_ANDROID_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.karadeniz.dijitalagi
# App Store metadata + uygulama içi yasal linkler (https:// zorunlu; boşsa uygulama içi ekran açılır)
# EXPO_PUBLIC_TERMS_OF_USE_URL=https://litxtech.com/vora/terms
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://litxtech.com/vora/privacy
# Apple IAP (App Store Server API — Supabase Edge Function secrets)
# APPLE_ISSUER_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# APPLE_BUNDLE_ID=com.karadeniz.dijitalagi
# Google Play Billing (Supabase Edge Function secrets)
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}
# GOOGLE_PLAY_PACKAGE_NAME=com.karadeniz.dijitalagi

# Dashboard: https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...
# Webhook endpoint: https://<project-ref>.supabase.co/functions/v1/stripe-webhook
# Events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
# Platform desteği (gönüllü bağış): stripe-create-contribution-checkout edge function
# Paketler: ₺159 / ₺259 / ₺359 — Stripe Dashboard'da ayrı ürün gerekmez (price_data kullanılır)
